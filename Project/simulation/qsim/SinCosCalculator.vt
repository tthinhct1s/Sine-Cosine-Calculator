`timescale 1 ps/ 1 ps
module SinCosCalculator_vlg_sample_tst(
	CLK,
	Z,
	sampler_tx
);
input  CLK;
input [15:0] Z;
output sampler_tx;

reg sample;
time current_time;
always @(CLK or Z)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

