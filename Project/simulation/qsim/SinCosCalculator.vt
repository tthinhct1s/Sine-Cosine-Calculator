		$display ("     Expected value = %b", sin_expected_prev);
		$display ("     Real value = %b", sin_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_sin_exp[12] = sin_expected_prev[12];
	end
	if (
		( sin_expected_prev[13] !== 1'bx ) && ( sin_prev[13] !== sin_expected_prev[13] )
		&& ((sin_expected_prev[13] !== last_sin_exp[13]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port sin[13] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", sin_expected_prev);
		$display ("     Real value = %b", sin_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_sin_exp[13] = sin_expected_prev[13];
	end
	if (
		( sin_expected_prev[14] !== 1'bx ) && ( sin_prev[14] !== sin_expected_prev[14] )
		&& ((sin_expected_prev[14] !== last_sin_exp[14]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port sin[14] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", sin_expected_prev);
		$display ("     Real value = %b", sin_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_sin_exp[14] = sin_expected_prev[14];
	end
	if (
		( sin_expected_prev[15] !== 1'bx ) && ( sin_prev[15] !== sin_expected_prev[15] )
		&& ((sin_expected_prev[15] !== last_sin_exp[15]) ||
			on_first_change[2])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port sin[15] :: @time = %t",  $realtime);
		$display ("     Expected value = %b", sin_expected_prev);
		$display ("     Real value = %b", sin_prev);
		nummismatches = nummismatches + 1;
		on_first_change[2] = 1'b0;
		last_sin_exp[15] = sin_expected_prev[15];
	end

	trigger <= ~trigger;
end
initial 

begin 
$timeformat(-12,3," ps",6);
#1000000;
if (nummismatches > 0)
	$display ("%d mismatched vectors : Simulation failed !",nummismatches);
else
	$display ("Simulation passed !");
$finish;
end 
endmodule

module SinCosCalculator_vlg_vec_tst();
// constants                                           
// general purpose registers
reg CLK;
reg [15:0] Z;
// wires                                               
wire [15:0] cos;
wire [15:0] sin;

wire sampler;                             

// assign statements (if any)                          
SinCosCalculator i1 (
// port map - connection between master ports and signals/registers   
	.CLK(CLK),
	.cos(cos),
	.sin(sin),
	.Z(Z)
);

// CLK
always
begin
	CLK = 1'b0;
	CLK = #10000 1'b1;
	#10000;
end 
// Z[ 15 ]
initial
begin
	Z[15] = 1'b1;
	Z[15] = #20000 1'b0;
end 
// Z[ 14 ]
initial
begin
	Z[14] = 1'b1;
	Z[14] = #20000 1'b0;
end 
// Z[ 13 ]
initial
begin
	Z[13] = 1'b0;
end 
// Z[ 12 ]
initial
begin
	Z[12] = 1'b0;
end 
// Z[ 11 ]
initial
begin
	Z[11] = 1'b0;
end 
// Z[ 10 ]
initial
begin
	Z[10] = 1'b1;
	Z[10] = #20000 1'b0;
end 
// Z[ 9 ]
initial
begin
	Z[9] = 1'b0;
end 
// Z[ 8 ]
initial
begin
	Z[8] = 1'b1;
	Z[8] = #20000 1'b0;
end 
// Z[ 7 ]
initial
begin
	Z[7] = 1'b0;
end 
// Z[ 6 ]
initial
begin
	Z[6] = 1'b1;
	Z[6] = #20000 1'b0;
end 
// Z[ 5 ]
initial
begin
	Z[5] = 1'b0;
end 
// Z[ 4 ]
initial
begin
	Z[4] = 1'b1;
	Z[4] = #20000 1'b0;
end 
// Z[ 3 ]
initial
begin
	Z[3] = 1'b1;
	Z[3] = #20000 1'b0;
end 
// Z[ 2 ]
initial
begin
	Z[2] = 1'b1;
	Z[2] = #20000 1'b0;
end 
// Z[ 1 ]
initial
begin
	Z[1] = 1'b0;
end 
// Z[ 0 ]
initial
begin
	Z[0] = 1'b0;
end 

SinCosCalculator_vlg_sample_tst tb_sample (
	.CLK(CLK),
	.Z(Z),
	.sampler_tx(sampler)
);

SinCosCalculator_vlg_check_tst tb_out(
	.cos(cos),
	.sin(sin),
	.sampler_rx(sampler)
);
endmodule

